# ── OpenSweep local dev environment ─────────────────────────────────────────────
# Copy to .env and adjust as needed. Localhost-only by default. Zitadel login
# is REQUIRED in every environment: after the first `docker compose up -d`,
# run scripts/zitadel-dev-setup.sh once — it configures the bundled
# Zitadel and fills the ZITADEL_*/VITE_ZITADEL_* vars below.
#
# ── Production deploy (production compose lives in the private infra overlay) ─
# 1. Point DNS for OPENSWEEP_DOMAIN at the server (Caddy auto-provisions TLS).
# 2. Fill in: OPENSWEEP_DOMAIN, OPENSWEEP_AUTH_TOKEN (e.g. `openssl rand -hex 32`),
#    GITHUB_TOKEN, GITHUB_WEBHOOK_SECRET, NEO4J_PASSWORD (non-default!),
#    CLAUDE_CODE_OAUTH_TOKEN, OPENSWEEP_SECRETS_KEY (secrets at rest — see below),
#    and set:
#      ALLOWED_ORIGINS=https://<OPENSWEEP_DOMAIN>
#      OPENSWEEP_WEBHOOK_PUBLIC_BASE_URL=https://<OPENSWEEP_DOMAIN>
#    ENVIRONMENT=production enables startup guards: the backend REFUSES to
#    boot without auth configured (OPENSWEEP_AUTH_TOKEN or ZITADEL_ISSUER) or
#    with the default Neo4j password, and warns when OPENSWEEP_SECRETS_KEY is
#    empty (secrets would be stored in plaintext).
# 3. Deploy with your production compose / orchestrator.

# Environment
ENVIRONMENT=local
LOG_LEVEL=INFO
LOG_SERVICE_NAME=opensweep_backend

# Neo4j
NEO4J_HOST=opensweep_neo4j
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=koalapassword

# Redis (broker, cache, pub/sub)
REDIS_HOST=opensweep_redis
REDIS_PORT=6379
REDIS_ACCESS_KEY=

# Zitadel OIDC is the only user auth in every environment (dev bundles it;
# ./start.sh configures it automatically).
OPENSWEEP_LOCAL_USER_EMAIL=
OPENSWEEP_LOCAL_USER_DISPLAY_NAME=

# Shared-secret token auth (v1 internet hardening). Empty = auth disabled
# (local dev). When set, every request needs `Authorization: Bearer <token>`
# or `X-OpenSweep-Auth: <token>` (WS/SSE: `?auth_token=`); /health and the
# HMAC-verified GitHub webhook stay open. In the browser, set it once via
# devtools: localStorage.setItem('opensweep_auth_token', '<token>')
OPENSWEEP_AUTH_TOKEN=

# Run-token secret — HMAC key for the per-run executor tokens (osrt_…) that
# agents present on the /mcp/platform callback surface. Falls back to
# OPENSWEEP_AUTH_TOKEN when empty. REQUIRED when auth is enforced via
# ZITADEL_ISSUER alone: without a secret, executor MCP callbacks 401 (the
# server "connects" but lists zero tools). Generate: openssl rand -hex 32
OPENSWEEP_RUN_TOKEN_SECRET=

# Dedicated HMAC key for GitHub App state nonces (install/manifest flows).
# Falls back to OPENSWEEP_RUN_TOKEN_SECRET, then OPENSWEEP_AUTH_TOKEN, with a startup
# warning. Generate: openssl rand -hex 32
OPENSWEEP_STATE_SIGNING_SECRET=

# Encrypts secrets at rest (GitHub App credentials file, LLM provider
# credentials) — enc:v1: Fernet. Generate ONCE (openssl rand -hex 32) and
# BACK IT UP: losing it makes sealed secrets unrecoverable. Empty = plaintext
# at rest (warning when ENVIRONMENT=production).
OPENSWEEP_SECRETS_KEY=

# Comma-separated previous keys, kept during rotation. Runbook: set the new
# OPENSWEEP_SECRETS_KEY, move the old key into the fallbacks, redeploy (the
# startup pass re-seals everything under the new key), then clear this.
OPENSWEEP_SECRETS_KEY_FALLBACKS=

# ── Zitadel OIDC (multi-user auth + roles) ──────────────────────────────────
# REQUIRED in every environment: the backend refuses to boot and the frontend
# refuses to mount without it (Zitadel is the only supported user auth).
# Coexists with OPENSWEEP_AUTH_TOKEN (browsers log in via Zitadel;
# internal/executor clients keep the token).
#
# Local dev (Zitadel is part of the default compose stack; the values below
# are written automatically by scripts/zitadel-dev-setup.sh):
#   ZITADEL_ISSUER=http://localhost:8300
#   ZITADEL_INTERNAL_URL=http://opensweep_zitadel:8080
#   VITE_ZITADEL_AUTHORITY=http://localhost:8300
# Production (production Zitadel stack):
#   ZITADEL_ISSUER=https://<ZITADEL_DOMAIN>   (no ZITADEL_INTERNAL_URL needed)
#   VITE_ZITADEL_AUTHORITY=https://<ZITADEL_DOMAIN>
ZITADEL_ISSUER=
ZITADEL_CLIENT_ID=
ZITADEL_PROJECT_ID=
ZITADEL_INTERNAL_URL=
# Frontend build-time vars (Vite) — same client id as ZITADEL_CLIENT_ID.
VITE_ZITADEL_AUTHORITY=
VITE_ZITADEL_CLIENT_ID=
# Zitadel stack itself (production Zitadel stack services):
# auth.<your-domain>; DNS → server, assigned to opensweep_caddy in Coolify.
ZITADEL_DOMAIN=
# Exactly 32 chars (`openssl rand -hex 16`). Encrypts Zitadel data at rest —
# generate once, back it up, NEVER change it afterwards.
ZITADEL_MASTERKEY=
ZITADEL_DB_PASSWORD=
# Prod first-init only (production Zitadel stack): RFC3339
# expiration for the admin-bootstrap machine PAT — set it ~90 days out
# (e.g. 2026-10-10T00:00:00Z). Empty = legacy no-expiry default.
ZITADEL_BOOTSTRAP_PAT_EXPIRATION=

# Public domain for the production Caddy edge — DNS must point here before
# first start.
OPENSWEEP_DOMAIN=

# Writable sandbox workspaces (bind-mounted in docker-compose).
# Host paths shown in the UI; container paths used by the backend.
# Sandboxes are fresh `git clone`s from GitHub (requires GITHUB_TOKEN).
OPENSWEEP_SANDBOX_HOST_MOUNT=/host/sandboxes
OPENSWEEP_SANDBOX_HOST_PATH=~/.opensweep/sandboxes
OPENSWEEP_SANDBOX_RETENTION_HOURS=24
# Clone depth for sandbox clones; review-runs need enough history for a
# merge-base (git diff base...head). 0 = full clone.
OPENSWEEP_SANDBOX_CLONE_DEPTH=200

# GitHub auth — two paths:
#   1. Access token (simplest): set GITHUB_TOKEN below (or paste one in the
#      UI, Settings → GitHub). A token set here auto-connects to the platform
#      admin's org on their first login — zero UI steps. Use a fine-grained
#      token scoped to the repos OpenSweep should see (Contents + Pull
#      requests read/write).
#   2. GitHub App: provisioned by `scripts/github-app-setup.sh dev` (one
#      browser click — fills the GITHUB_APP_*/GITHUB_WEBHOOK_SECRET vars below
#      and restarts the containers). Adds installation tokens + auto-register
#      webhooks.
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# Private key PEM, base64-encoded (raw PEM also accepted). Alternatively
# point GITHUB_PRIVATE_KEY_PATH at a PEM file.
GITHUB_APP_PRIVATE_KEY=
GITHUB_PRIVATE_KEY_PATH=
# Webhook HMAC secret — the App's manifest-issued secret (setup script), or a
# manual repo-webhook secret in PAT mode.
GITHUB_WEBHOOK_SECRET=
# Auto-dispatch a review run when a PR opens / its head moves (default off).
OPENSWEEP_REVIEW_ON_SYNC=false
# Quota pause/resume: retry window (minutes) and max retries per run.
OPENSWEEP_QUOTA_RETRY_MINUTES=30
OPENSWEEP_QUOTA_MAX_RETRIES=6
# Stuck-run repair: a queued/running run whose transcript has been silent this
# long is failed by the reconciler (covers local providers, which have no wall
# ceiling). Restarts of backend/worker also fail their own orphans immediately.
OPENSWEEP_RUN_LIVENESS_TIMEOUT_SECONDS=900

# Claude Code subscription — long-lived headless OAuth token.
# Generate once on your host with:  claude setup-token
# The in-container `claude` CLI reads this env var and authenticates without a
# Keychain or interactive /login. Leave empty to disable the claude_subscription
# provider; the Anthropic API kind still works with ANTHROPIC_API_KEY.
CLAUDE_CODE_OAUTH_TOKEN=

# Optional direct-API keys (only needed if you use the claude_api / openai_api
# LLMProvider kinds — separate from the subscription CLIs).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Public base URL OpenSweep advertises for inbound webhook callbacks.
# Localhost works in dev; external agent systems need a tunnel (ngrok/cloudflared).
OPENSWEEP_WEBHOOK_PUBLIC_BASE_URL=http://127.0.0.1:8001

# Platform seed data (prompts, policies) is applied automatically at startup;
# dev users are created by scripts/zitadel-dev-setup.sh.

# ── Open-web research tools (web_search / fetch_url platform tools) ─────────
# SearXNG base URL for web_search mode="web". The compose files set this to
# the bundled service (http://opensweep_searxng:8080) on backend + worker; only
# set it here when running the backend outside compose. Empty = web mode
# returns "unavailable" (github/hackernews/arxiv modes still work).
SEARXNG_URL=
# secret_key of the bundled SearXNG instance (`openssl rand -hex 32`).
# Compose falls back to a dev-only default when empty.
SEARXNG_SECRET=

# MCP
MCP_ENABLED=true
MCP_MOUNT_PATH=/mcp
# Base URL agent subprocesses use to reach the platform MCP mounts. Default
# assumes the compose service name; override where the backend answers under
# a different hostname (Coolify service naming, host-network dev).
#OPENSWEEP_BACKEND_INTERNAL_URL=http://opensweep_backend:8000

# CORS — OpenSweep host ports shifted to coexist with sibling stacks on this machine
ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# Frontend (read by Vite at build time)
VITE_BACKEND_URL=http://127.0.0.1:8001
VITE_APP_NAME=OpenSweep

# SPA origin for backend browser redirects (GitHub App callback). Leave empty
# behind Caddy (same origin); set when backend has its own origin (dev/tunnel).
OPENSWEEP_FRONTEND_BASE_URL=
